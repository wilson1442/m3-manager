# MongoDB connection
# Example: mongodb://localhost:27017  or  mongodb://user:pass@host:27017
MONGO_URL=mongodb://localhost:27017

# Database name used within the Mongo instance
DB_NAME=m3u_panel

# JWT signing secret — MUST be long, random, and unique per environment.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this value invalidates all existing JWTs (users will need to log in again).
SECRET_KEY=change-me-generate-with-secrets-token_urlsafe

# Comma-separated list of allowed origins for CORS. Include every domain the
# frontend will be served from. Do NOT use "*" in production.
# Example:
# CORS_ORIGINS=http://localhost:3000,https://m3u.example.com
CORS_ORIGINS=http://localhost:3000
