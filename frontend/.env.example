# As of 1.1.2 the frontend calls the backend via the relative path /api
# rather than a hardcoded domain. This means the same bundle works on any
# origin — LAN IP, Cloudflare tunnel, localhost — as long as your reverse
# proxy forwards /api/* to the FastAPI backend. nginx is already configured
# this way in the stock install.
#
# If you need to override this for a development setup where the frontend
# and backend run on different origins, set REACT_APP_BACKEND_URL here AND
# update src/pages/*.js to use `${BACKEND_URL}/api` again. Hardcoding a
# full URL bakes the value into the bundle at build time, so any change
# requires a rebuild.

# CRA dev server websocket port (development only)
WDS_SOCKET_PORT=443

# Feature flags
REACT_APP_ENABLE_VISUAL_EDITS=false
ENABLE_HEALTH_CHECK=false
