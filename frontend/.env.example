# Base URL for the backend API.
#
# Recommended: leave empty or point at the same origin as the frontend and let
# nginx proxy /api/* to the backend. Hardcoding a full URL (e.g.
# https://m3u.example.com) bakes the value into the JS bundle at build time,
# so the frontend must be rebuilt any time the backend URL changes.
REACT_APP_BACKEND_URL=https://m3u.example.com

# CRA dev server websocket port (only used in development)
WDS_SOCKET_PORT=443

# Feature flags
REACT_APP_ENABLE_VISUAL_EDITS=false
ENABLE_HEALTH_CHECK=false
